// Prisma Schema for 问心 AI
// 数据库：Neon PostgreSQL
// 文档：https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== 用户系统 ====================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  // 用户基本信息
  age           Int?
  gender        String?
  status        String?   // 情感状态
  // 偏好设置
  preferences   Json      @default("{}")
  // 订阅信息
  subscription  Json      @default("{}")
  // 时间戳
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // 关联
  sessions      Session[]
  messages      Message[]
  actions       Action[]
  accounts      Account[]
  authentications Authentication[]

  @@map("users")
}

// NextAuth.js 标准表
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Authentication {
  id            String  @id @default(cuid())
  userId        String
  provider      String
  providerAccountId String
  email         String?
  expiresAt     DateTime?
  // 验证码
  code          String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("authentications")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ==================== 对话系统 ====================

model Session {
  id          String   @id @default(cuid())
  userId      String
  title       String   // 对话标题（自动生成）
  // 用户上下文（解读时的填表数据）
  context     Json     @default("{}")
  // AI 自动生成的摘要
  summary     String?
  // 关键洞察列表
  insights    Json     @default("[]")
  // 当前情绪标签
  emotion     String?
  // 话题标签
  topics      Json     @default("[]")
  // 状态
  status      String   @default("active") // active / archived
  // 时间
  startedAt   DateTime @default(now())
  lastMessageAt DateTime @default(now())
  endedAt     DateTime?

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
  actions   Action[]

  @@index([userId])
  @@index([status])
  @@index([lastMessageAt])
  @@map("sessions")
}

model Message {
  id        String   @id @default(cuid())
  sessionId String
  userId    String
  role      String   // user / assistant
  content   String   @db.Text
  // 元数据
  metadata  Json     @default("{}")
  // 情感标签
  emotion   String?
  // 话题
  topics    Json     @default("[]")
  // 时间
  timestamp DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionId, timestamp])
  @@index([userId])
  @@map("messages")
}

// ==================== 行动系统 ====================

model Action {
  id          String   @id @default(cuid())
  userId      String
  sessionId   String?
  // 行动内容
  title       String
  description String   @db.Text
  // 类别
  category    String   // self-awareness / relationship / career / health
  // 时长
  durationDays Int     @default(7)
  // 开始日期
  startDate   DateTime @default(now())
  // 打卡记录（JSON 数组）
  checkIns    Json     @default("[]")
  // 完成率（0-1）
  completionRate Float  @default(0)
  // 状态
  status      String   @default("active") // active / completed / abandoned
  // AI 反馈
  aiFeedback  String?  @db.Text
  // 时间
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  session Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([sessionId])
  @@map("actions")
}

// ==================== 情绪追踪 ====================

model MoodEntry {
  id        String   @id @default(cuid())
  userId    String
  // 情绪分数（1-10）
  score     Int
  // 情绪标签
  emotion   String
  // 备注
  note      String?  @db.Text
  // 时间
  date      DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([userId, date])
  @@map("mood_entries")
}