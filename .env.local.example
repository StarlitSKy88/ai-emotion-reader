# ====== LLM 配置（必填）======
# 支持任何 OpenAI 兼容的 API，一行切换模型

# 当前使用：MiniMax-M3
LLM_PROVIDER=minimax
LLM_API_KEY=请填写你的_API_Key
LLM_BASE_URL=https://api.minimaxi.com/v1
LLM_MODEL=MiniMax-M3

# ====== 备选模型（注释掉的，按需启用）======

# --- DeepSeek ---
# LLM_PROVIDER=deepseek
# LLM_API_KEY=sk-xxx
# LLM_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-chat

# --- 月之暗面 Kimi ---
# LLM_PROVIDER=kimi
# LLM_API_KEY=sk-xxx
# LLM_BASE_URL=https://api.moonshot.cn/v1
# LLM_MODEL=moonshot-v1-8k-vision-preview

# --- 智谱 GLM ---
# LLM_PROVIDER=glm
# LLM_API_KEY=xxx
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# LLM_MODEL=glm-4-flash

# --- 通义千问 ---
# LLM_PROVIDER=qwen
# LLM_API_KEY=sk-xxx
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-turbo

# ====== 网站元数据（可选）======
NEXT_PUBLIC_SITE_NAME=问心 AI
NEXT_PUBLIC_WECHAT_ID=your_wechat_id_here
NEXT_PUBLIC_SITE_URL=https://your-domain.pages.dev

# ====== 时区（可选）======
# 每日任务生成、cron 推送时段判断、报告聚合用的默认时区（IANA 时区名）
# 不配置则默认 Asia/Shanghai；跨时区情侣场景可改为 America/Los_Angeles 等
TIMEZONE=Asia/Shanghai

# ====== 微信小程序登录（Phase 0）======
WECHAT_MINIAPP_APPID=your_miniapp_appid
WECHAT_MINIAPP_SECRET=your_miniapp_secret
JWT_SECRET=your_jwt_secret_change_in_prod

# ====== 微信支付（Phase 2.4，解锁深度内容）======
WECHAT_PAY_APPID=your_miniapp_appid
WECHAT_PAY_MCHID=your_mch_id
WECHAT_PAY_API_KEY=your_api_v3_key
WECHAT_PAY_SERIAL_NO=your_cert_serial_no
WECHAT_PAY_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
WECHAT_PAY_NOTIFY_URL=https://your-domain.com/api/wechat/pay/notify
# 微信支付平台公钥（PEM 格式，用于回调验签，Phase 3 复审 B-2 要求生产必填）
WECHAT_PAY_PLATFORM_CERT_PEM=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----
# 订阅支付回调地址（Phase 5.3，独立于解锁回调；未配置时回退到 WECHAT_PAY_NOTIFY_URL）
WECHAT_PAY_SUBSCRIPTION_NOTIFY_URL=https://your-domain.com/api/subscription/notify

# ====== 文件上传（Phase 4.4 task/chat 图片上传）======
# 生产环境对象存储 CDN 域名（如 https://cdn.example.com），未配置则用同源 /uploads/
UPLOAD_BASE_URL=

# ====== 订阅消息推送（Phase 4.5）======
# 微信小程序订阅消息模板 ID（在微信公众平台后台申请）
WECHAT_TMPL_DAILY_TASK=your_daily_task_template_id
WECHAT_TMPL_TASK_SUMMARY=your_task_summary_template_id
# 定时触发 cron 鉴权 secret（外部调度器调用 /api/push/cron 时带 Bearer 头）
CRON_SECRET=your_cron_secret

# ====== Admin 看板（Phase 6.7/6.8）======
# 访问 /admin/dashboard 需要的 token（≥32 字符随机串，未配置则看板不可用）
ADMIN_TOKEN=your_admin_token_change_in_prod

# ====== 小程序码（Phase 6.2）======
# 小程序原始 ID，用于落地页搜索引导（在微信公众平台后台 → 设置 → 基本设置 查看）
NEXT_PUBLIC_WECHAT_MINIAPP_ID=gh_your_miniapp_original_id